# ─────────────────────────────────────────────────────────────────────────────
# BestPrice — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to ./database.db if not set
# BESTPRICE_DB_PATH=/data/bestprice.db

# ── Product ───────────────────────────────────────────────────────────────────
# Slug of the default product shown on load. See config.py → PRODUCTS dict.
BESTPRICE_PRODUCT=samsung-m34

# ── Model thresholds (optional overrides) ────────────────────────────────────
# BARGAIN_THRESHOLD=30
# NEAR_LOW_PCT=0.05
# MIN_DISCOUNT_LOW_RULE=10

# ── Email alerts ──────────────────────────────────────────────────────────────
# Use a Gmail App Password (not your main password).
# https://support.google.com/accounts/answer/185833
ALERT_EMAIL_FROM=your-sender@gmail.com
ALERT_EMAIL_TO=your-email@example.com
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_PASSWORD=your-gmail-app-password

# ── Webhook alerts (Discord or Slack) ────────────────────────────────────────
# Discord:  Server Settings → Integrations → Webhooks → Copy URL
# Slack:    api.slack.com → Your Apps → Incoming Webhooks
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_TIMEOUT=15
SCRAPER_RETRIES=3

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL=300
